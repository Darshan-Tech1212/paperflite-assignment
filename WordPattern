import java.util.*;

public class Problem3_WordPattern {

    public static boolean wordPattern(String pattern, String s) {
        String[] words = s.split(" ");

        if (pattern.length() != words.length) return false;

        HashMap<Character, String> map = new HashMap<>();
        HashSet<String> used = new HashSet<>();

        for (int i = 0; i < pattern.length(); i++) {
            char ch = pattern.charAt(i);
            String word = words[i];

            if (map.containsKey(ch)) {
                if (!map.get(ch).equals(word)) {
                    return false;
                }
            } else {
                if (used.contains(word)) {
                    return false;
                }
                map.put(ch, word);
                used.add(word);
            }
        }

        return true;
    }

    public static void main(String[] args) {
        // Example 1
        System.out.println("Output 1: " + wordPattern("abba", "dog cat cat dog")); // Expected: true

        // Example 2
        System.out.println("Output 2: " + wordPattern("abba", "dog cat cat fish")); // Expected: false

        // Example 3
        System.out.println("Output 3: " + wordPattern("aaaa", "dog cat cat dog")); // Expected: false
    }
}
